# Copy to .env and fill in whichever keys your chosen providers need.
# .env is gitignored -- never commit real keys.

# Needed for --model openai/...
OPENAI_API_KEY=

# Needed for --model anthropic/...
ANTHROPIC_API_KEY=

# Needed for --model openrouter/...
OPENROUTER_API_KEY=

# Needed for --search-backend tavily
TAVILY_API_KEY=

# Optional: override any Config field, e.g. RESEARCH_AGENT_MAX_LOOPS=5
